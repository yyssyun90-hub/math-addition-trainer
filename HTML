                // ===== Supabase 初始化 =====
                async initSupabase() {
                    try {
                        const configScript = document.getElementById('supabase-config');
                        if (!configScript) {
                            console.warn('Supabase 配置不存在');
                            return;
                        }

                        const config = JSON.parse(configScript.textContent);
                        
                        // 创建 Supabase 客户端
                        this.state.supabase = window.supabase.createClient(
                            config.supabaseUrl,
                            config.supabaseKey,
                            {
                                auth: {
                                    autoRefreshToken: true,
                                    persistSession: true
                                }
                            }
                        );

                        // 测试连接
                        const { error } = await this.state.supabase.auth.getSession();
                        if (error) throw error;

                        this.state.supabaseReady = true;
                        console.log('Supabase 连接成功');
                    } catch (error) {
                        console.error('Supabase 初始化失败:', error);
                        this.state.supabaseReady = false;
                    }
                }

                // ===== 云端同步 =====
                async syncToCloud() {
                    if (!this.state.supabaseReady || !this.state.currentUser || !this.state.isOnline) {
                        return false;
                    }

                    try {
                        const accuracy = this.state.attempts > 0
                            ? Math.round((this.state.correct / this.state.attempts) * 100)
                            : 0;

                        // 保存游戏记录
                        const { error: gameError } = await this.state.supabase
                            .from('game_records')
                            .insert([{
                                user_id: this.state.currentUser.id,
                                score: this.state.score,
                                completed: this.state.completed,
                                accuracy: accuracy,
                                mode: this.state.currentMode,
                                difficulty: this.state.currentDifficulty,
                                created_at: new Date().toISOString()
                            }]);

                        if (gameError) throw gameError;

                        // 保存错题本
                        if (this.state.wrongQuestions.length > 0) {
                            const wrongRecords = this.state.wrongQuestions.map(w => ({
                                user_id: this.state.currentUser.id,
                                target: w.target,
                                num1: w.num1,
                                num2: w.num2,
                                created_at: w.timestamp
                            }));

                            const { error: wrongError } = await this.state.supabase
                                .from('wrong_questions')
                                .insert(wrongRecords);

                            if (wrongError) throw wrongError;
                        }

                        this.showFeedback('syncSuccess', '#4CAF50');
                        return true;
                    } catch (error) {
                        console.error('同步失败:', error);
                        this.showFeedback('syncFailed', '#ff4444');
                        return false;
                    }
                }

                async syncFromCloud() {
                    if (!this.state.supabaseReady || !this.state.currentUser || !this.state.isOnline) {
                        return false;
                    }

                    try {
                        // 拉取游戏记录
                        const { data: games, error: gameError } = await this.state.supabase
                            .from('game_records')
                            .select('*')
                            .eq('user_id', this.state.currentUser.id)
                            .order('created_at', { ascending: false })
                            .limit(50);

                        if (gameError) throw gameError;

                        // 拉取错题本
                        const { data: wrong, error: wrongError } = await this.state.supabase
                            .from('wrong_questions')
                            .select('*')
                            .eq('user_id', this.state.currentUser.id)
                            .order('created_at', { ascending: false })
                            .limit(200);

                        if (wrongError) throw wrongError;

                        // 合并到本地（这里简化处理，实际应该做冲突解决）
                        if (games && games.length > 0) {
                            // 可以选择性地合并
                        }

                        if (wrong && wrong.length > 0) {
                            this.state.wrongQuestions = wrong.map(w => ({
                                target: w.target,
                                num1: w.num1,
                                num2: w.num2,
                                timestamp: w.created_at
                            }));
                        }

                        this.showFeedback('syncSuccess', '#4CAF50');
                        return true;
                    } catch (error) {
                        console.error('拉取失败:', error);
                        this.showFeedback('syncFailed', '#ff4444');
                        return false;
                    }
                }

