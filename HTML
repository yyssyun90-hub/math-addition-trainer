<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <meta name="theme-color" content="#ff69b4">
    <title>🍬 糖果数学消消乐 · 云端同步版</title>
    <style>
        /* ===== 糖果可爱风 ===== */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Comic Neue', 'Chalkboard SE', cursive, sans-serif;
            background: linear-gradient(145deg, #fff0f5, #ffe4e1, #fff0e0);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
            -webkit-tap-highlight-color: transparent;
        }

        .game-container {
            max-width: 900px;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 80px 80px 40px 40px;
            box-shadow: 0 20px 0 #ffb6c1, 0 30px 40px rgba(255, 105, 180, 0.3);
            padding: 30px 25px;
            border: 3px solid white;
            position: relative;
        }

        /* ===== 用户信息栏 ===== */
        .user-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding: 10px 20px;
            background: #fff0f5;
            border-radius: 50px;
            border: 2px solid #ffb6c1;
            box-shadow: 0 4px 0 #ff69b4;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(145deg, #ff69b4, #ff1493);
            border: 3px solid white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: white;
            box-shadow: 0 4px 0 #8b008b;
        }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: bold;
            font-size: 1.2rem;
            color: #ff1493;
        }

        .user-status {
            font-size: 0.9rem;
            color: #666;
        }

        .auth-buttons {
            display: flex;
            gap: 10px;
        }

        .auth-btn {
            padding: 8px 20px;
            border: none;
            border-radius: 40px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.1s ease;
            border: 2px solid white;
            box-shadow: 0 4px 0 #8b008b;
        }

        .auth-btn.login {
            background: linear-gradient(145deg, #ff69b4, #ff1493);
            color: white;
        }

        .auth-btn.register {
            background: linear-gradient(145deg, #ffd700, #ffa500);
            color: white;
        }

        .auth-btn.logout {
            background: linear-gradient(145deg, #ff6b6b, #ff4757);
            color: white;
        }

        .auth-btn:active {
            transform: translateY(3px);
            box-shadow: 0 1px 0 #8b008b;
        }

        .auth-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: 0 2px 0 #8b008b;
            pointer-events: none;
        }

        /* ===== 语言切换 ===== */
        .language-switch {
            position: absolute;
            top: 20px;
            right: 30px;
            z-index: 100;
        }

        .lang-btn {
            padding: 8px 20px;
            border: none;
            border-radius: 40px;
            background: linear-gradient(145deg, #9b59b6, #8e44ad);
            color: white;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 0 #6c3483;
            border: 2px solid white;
            transition: all 0.1s ease;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .lang-btn:active {
            transform: translateY(3px);
            box-shadow: 0 1px 0 #6c3483;
        }

        .lang-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: 0 2px 0 #6c3483;
        }

        /* ===== 头部 ===== */
        .header {
            text-align: center;
            margin-bottom: 25px;
            margin-top: 20px;
        }

        h1 {
            font-size: 2.8rem;
            background: linear-gradient(145deg, #ff69b4, #ff1493, #ff4500);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 3px 3px 0 #ffff00, 5px 5px 0 rgba(255, 20, 147, 0.3);
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .candy-row {
            font-size: 2rem;
            display: flex;
            justify-content: center;
            gap: 15px;
        }

        .candy {
            animation: bounce 2s infinite;
        }

        .candy:nth-child(2) { animation-delay: 0.2s; }
        .candy:nth-child(3) { animation-delay: 0.4s; }
        .candy:nth-child(4) { animation-delay: 0.6s; }

        @keyframes bounce {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(5deg); }
        }

        /* ===== 游戏设置区域 ===== */
        .settings-panel {
            background: #fff5f5;
            border: 3px solid #ffb6c1;
            border-radius: 50px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 8px 0 #ff69b4;
        }

        .mode-row {
            display: flex;
            gap: 12px;
            margin-bottom: 15px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .mode-btn {
            padding: 12px 25px;
            border: none;
            border-radius: 40px;
            font-size: 1.2rem;
            font-weight: bold;
            background: white;
            color: #ff69b4;
            border: 3px solid #ffb6c1;
            cursor: pointer;
            transition: all 0.1s ease;
            box-shadow: 0 4px 0 #ffb6c1;
            flex: 1;
            min-width: 140px;
            min-height: 50px;
        }

        .mode-btn.active {
            background: linear-gradient(145deg, #ff69b4, #ff1493);
            color: white;
            border-color: white;
            box-shadow: 0 6px 0 #8b008b;
            transform: translateY(-2px);
        }

        .mode-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: 0 2px 0 #ffb6c1;
        }

        .difficulty-row {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .difficulty-btn {
            padding: 8px 20px;
            border: none;
            border-radius: 30px;
            font-size: 1rem;
            font-weight: bold;
            background: white;
            color: #666;
            border: 2px solid #ddd;
            cursor: pointer;
            transition: all 0.1s ease;
            flex: 1;
            min-width: 100px;
            min-height: 45px;
        }

        .difficulty-btn.easy.active {
            background: #6ab04c;
            color: white;
            border-color: white;
            box-shadow: 0 4px 0 #2e7d32;
        }

        .difficulty-btn.medium.active {
            background: #ffb347;
            color: white;
            border-color: white;
            box-shadow: 0 4px 0 #ff8c00;
        }

        .difficulty-btn.hard.active {
            background: #ff6b6b;
            color: white;
            border-color: white;
            box-shadow: 0 4px 0 #c0392b;
        }

        .difficulty-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: 0 2px 0 #ddd;
        }

        .start-btn-wrapper {
            display: flex;
            justify-content: center;
            margin-top: 10px;
        }

        .start-btn {
            padding: 18px 50px;
            font-size: 1.8rem;
            background: linear-gradient(145deg, #ff69b4, #ff1493);
            border: none;
            border-radius: 60px;
            color: white;
            font-weight: bold;
            text-shadow: 2px 2px 0 #8b008b;
            cursor: pointer;
            box-shadow: 0 10px 0 #8b008b, 0 5px 20px rgba(255, 20, 147, 0.5);
            transition: all 0.1s ease;
            display: inline-flex;
            align-items: center;
            gap: 15px;
            border: 3px solid white;
            min-height: 70px;
        }

        .start-btn:active {
            transform: translateY(6px);
            box-shadow: 0 4px 0 #8b008b;
        }

        .start-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: 0 4px 0 #8b008b;
        }

        /* ===== 游戏信息卡片 ===== */
        .stats-panel {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            background: #fff0f5;
            border: 3px solid #ffb6c1;
            border-radius: 50px;
            padding: 20px 15px;
            margin-bottom: 25px;
            box-shadow: 0 8px 0 #ff69b4;
        }

        .stat-item {
            text-align: center;
        }

        .stat-label {
            font-size: 0.9rem;
            color: #ff1493;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 900;
            color: #8b008b;
            line-height: 1.2;
            text-shadow: 1px 1px 0 #ffff00;
        }

        /* ===== 目标和 ===== */
        .target-box {
            background: radial-gradient(circle at 30% 30%, #ffd700, #ffa500, #ff8c00);
            width: 140px;
            height: 140px;
            border-radius: 50%;
            margin: 0 auto 25px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border: 5px solid white;
            box-shadow: 0 12px 0 #ff8c00, 0 15px 25px rgba(0,0,0,0.2);
            position: relative;
        }

        .target-box::before {
            content: '🎯';
            position: absolute;
            top: -20px;
            left: -20px;
            font-size: 2rem;
            transform: rotate(-20deg);
        }

        .target-box::after {
            content: '🍬';
            position: absolute;
            bottom: -20px;
            right: -20px;
            font-size: 2rem;
            transform: rotate(20deg);
        }

        .target-label {
            color: white;
            font-size: 1.1rem;
            text-shadow: 2px 2px 0 #ff4500;
        }

        .target-number {
            color: white;
            font-size: 4rem;
            font-weight: 900;
            line-height: 1;
            text-shadow: 4px 4px 0 #ff4500;
        }

        /* ===== 游戏网格 - 糖果多样化颜色 ===== */
        .game-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
            margin: 20px 0 30px;
            padding: 15px;
            background: #fff0f5;
            border-radius: 60px;
            border: 3px dashed #ffb6c1;
        }

        .number-card {
            aspect-ratio: 1;
            min-width: 60px;
            min-height: 60px;
            border: 3px solid white;
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.3rem;
            font-weight: 800;
            color: white;
            text-shadow: 2px 2px 0 #000000, 3px 3px 0 rgba(0,0,0,0.5);
            box-shadow: 0 8px 0 rgba(0,0,0,0.2), 0 10px 20px rgba(0,0,0,0.2);
            cursor: pointer;
            transition: all 0.1s ease;
            transform: rotate(0deg);
        }

        .number-card[data-color="0"] { background: radial-gradient(circle at 30% 30%, #ff9a9e, #fad0c4); }
        .number-card[data-color="1"] { background: radial-gradient(circle at 30% 30%, #a8edea, #fed6e3); }
        .number-card[data-color="2"] { background: radial-gradient(circle at 30% 30%, #ffd3b6, #ffaaa5); }
        .number-card[data-color="3"] { background: radial-gradient(circle at 30% 30%, #d4fc79, #96e6a1); }
        .number-card[data-color="4"] { background: radial-gradient(circle at 30% 30%, #84fab0, #8fd3f4); }
        .number-card[data-color="5"] { background: radial-gradient(circle at 30% 30%, #fccb90, #ff9a9e); }
        .number-card[data-color="6"] { background: radial-gradient(circle at 30% 30%, #fbc2eb, #a6c1ee); }
        .number-card[data-color="7"] { background: radial-gradient(circle at 30% 30%, #ff9a9e, #ffb6c1); }
        .number-card[data-color="8"] { background: radial-gradient(circle at 30% 30%, #ffd1d1, #ffb8b8); }
        .number-card[data-color="9"] { background: radial-gradient(circle at 30% 30%, #b2f0e5, #8ed6ff); }

        .number-card:hover {
            transform: scale(1.05) rotate(2deg);
            box-shadow: 0 10px 0 rgba(0,0,0,0.2), 0 15px 25px rgba(0,0,0,0.3);
        }

        .number-card.selected {
            transform: scale(1.08) rotate(3deg);
            border: 4px solid #ffff00;
            box-shadow: 0 10px 0 rgba(0,0,0,0.2), 0 18px 30px rgba(0,0,0,0.3);
            filter: brightness(1.1);
        }

        .number-card.matched {
            animation: candyPop 0.4s forwards;
        }

        .number-card:focus-visible {
            outline: 3px solid #ffff00;
            outline-offset: 2px;
        }

        @keyframes candyPop {
            0% { transform: scale(1) rotate(0deg); opacity: 1; }
            50% { transform: scale(1.4) rotate(10deg); opacity: 0.8; }
            100% { transform: scale(0) rotate(20deg); opacity: 0; }
        }

        /* ===== 控制按钮 ===== */
        .controls {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .candy-btn {
            padding: 14px 30px;
            border: none;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: bold;
            color: white;
            text-shadow: 2px 2px 0 #8b008b;
            cursor: pointer;
            transition: all 0.1s ease;
            box-shadow: 0 6px 0 #8b008b;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 2px solid white;
            min-width: 120px;
            min-height: 60px;
            justify-content: center;
        }

        .candy-btn:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 #8b008b;
        }

        .candy-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: 0 2px 0 #8b008b;
            pointer-events: none;
        }

        .candy-btn.primary {
            background: linear-gradient(145deg, #ff69b4, #ff1493);
        }

        .candy-btn.secondary {
            background: linear-gradient(145deg, #ffd700, #ffa500);
        }

        .candy-btn.warning {
            background: linear-gradient(145deg, #ff6b6b, #ff4757);
        }

        .candy-btn.home {
            background: linear-gradient(145deg, #9b59b6, #8e44ad);
        }

        .candy-btn.pause {
            background: linear-gradient(145deg, #00cec9, #00b894);
        }

        /* ===== 反馈消息 ===== */
        .feedback {
            text-align: center;
            font-size: 2.2rem;
            margin: 15px 0;
            min-height: 70px;
            font-weight: bold;
            transition: all 0.2s ease;
            text-shadow: 2px 2px 0 white;
        }

        /* ===== 游戏结束弹窗 ===== */
        .game-over-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .game-over-card {
            background: white;
            border-radius: 80px;
            padding: 35px;
            max-width: 500px;
            width: 90%;
            border: 4px solid #ff69b4;
            box-shadow: 0 20px 0 #ff1493, 0 30px 40px rgba(0,0,0,0.3);
            text-align: center;
            position: relative;
        }

        .close-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #ff6b6b;
            border: 2px solid white;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 4px 0 #c0392b;
            transition: all 0.1s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .close-btn:active {
            transform: translateY(3px);
            box-shadow: 0 1px 0 #c0392b;
        }

        .game-over-title {
            font-size: 2.5rem;
            color: #ff69b4;
            margin-bottom: 25px;
            text-shadow: 2px 2px 0 #ffff00;
        }

        .result-item {
            font-size: 1.3rem;
            margin: 15px 0;
            padding: 10px;
            background: #fff0f5;
            border-radius: 40px;
            border: 2px solid #ffb6c1;
        }

        .result-value {
            font-size: 2rem;
            font-weight: 900;
            color: #ff1493;
            margin-left: 10px;
        }

        .game-over-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .game-over-buttons .candy-btn {
            padding: 12px 25px;
            font-size: 1.1rem;
            min-width: 140px;
        }

        /* ===== 登录模态框 ===== */
        .auth-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
        }

        .auth-card {
            background: white;
            border-radius: 60px;
            padding: 40px;
            max-width: 400px;
            width: 90%;
            border: 4px solid #ff69b4;
            box-shadow: 0 20px 0 #ff1493;
            position: relative;
        }

        .auth-title {
            font-size: 2rem;
            color: #ff69b4;
            text-align: center;
            margin-bottom: 30px;
            text-shadow: 2px 2px 0 #ffff00;
        }

        .auth-input {
            width: 100%;
            padding: 15px 20px;
            margin: 10px 0;
            border: 3px solid #ffb6c1;
            border-radius: 40px;
            font-size: 1.1rem;
            font-family: inherit;
        }

        .auth-input:focus {
            outline: none;
            border-color: #ff69b4;
            box-shadow: 0 0 0 3px #ffff00;
        }

        .auth-error {
            color: #ff4444;
            text-align: center;
            margin: 10px 0;
            min-height: 30px;
            font-weight: bold;
        }

        .auth-switch {
            text-align: center;
            margin: 20px 0 10px;
            color: #666;
        }

        .auth-switch span {
            color: #ff69b4;
            font-weight: bold;
            cursor: pointer;
            text-decoration: underline;
        }

        .auth-submit-btn {
            width: 100%;
            font-size: 1.2rem;
            padding: 12px 30px;
            margin-top: 10px;
        }

        /* ===== 新手引导弹窗 ===== */
        .tutorial-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 3000;
        }

        .tutorial-card {
            background: white;
            border-radius: 60px;
            padding: 40px;
            max-width: 500px;
            width: 90%;
            border: 4px solid #ff69b4;
            box-shadow: 0 20px 0 #ff1493;
        }

        .tutorial-title {
            font-size: 2rem;
            color: #ff69b4;
            text-align: center;
            margin-bottom: 25px;
            text-shadow: 2px 2px 0 #ffff00;
        }

        .tutorial-list {
            list-style: none;
            margin: 20px 0;
        }

        .tutorial-list li {
            font-size: 1.2rem;
            margin: 15px 0;
            padding: 10px;
            background: #fff0f5;
            border-radius: 40px;
            border: 2px solid #ffb6c1;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .tutorial-list li span:first-child {
            font-size: 1.5rem;
        }

        .tutorial-start-btn {
            width: 100%;
            font-size: 1.2rem;
            padding: 12px 30px;
        }

        /* ===== 响应式 ===== */
        @media (max-width: 700px) {
            .game-container { padding: 20px 15px; }
            h1 { font-size: 2.2rem; }
            .game-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }
            .stats-panel { grid-template-columns: repeat(2, 1fr); }
            .number-card { 
                font-size: 1.8rem; 
                min-height: 70px;
                min-width: 70px;
            }
            .start-btn { font-size: 1.4rem; padding: 15px 30px; min-height: 60px; }
            .language-switch { top: 10px; right: 15px; }
            .user-bar { flex-direction: column; gap: 10px; }
            .candy-btn { min-height: 55px; padding: 12px 20px; }
        }

        @media (max-width: 500px) {
            .game-grid { grid-template-columns: repeat(3, 1fr); }
            .mode-btn { min-width: 120px; font-size: 1rem; }
            .target-box { width: 120px; height: 120px; }
            .target-number { font-size: 3rem; }
            .candy-btn { min-width: 100px; font-size: 1rem; }
        }

        @media (hover: none) and (pointer: coarse) {
            .number-card:hover { transform: none; }
            .candy-btn:hover { transform: none; }
        }
    </style>
    <!-- 加载 Supabase -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
    <div class="game-container">
        <!-- 用户栏 -->
        <div class="user-bar">
            <div class="user-info" id="user-info" style="display: none;">
                <div class="user-avatar" id="user-avatar">🍬</div>
                <div class="user-details">
                    <span class="user-name" id="user-name">游客</span>
                    <span class="user-status" id="user-status">离线模式</span>
                </div>
            </div>
            <div class="auth-buttons" id="auth-buttons">
                <!-- 动态生成 -->
            </div>
        </div>

        <!-- 语言切换按钮 -->
